# Local-only secret for the AI question generator (npm run questions:generate).
#
# 1. Copy this file to ".env"  (cp .env.example .env)
# 2. Paste your Anthropic API key below.
# 3. NEVER commit .env — it is gitignored, and is only read locally via
#    Node's --env-file flag. It never enters the repo, CI, or the hosted site.
#
# Get a key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
