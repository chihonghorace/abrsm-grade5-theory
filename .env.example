# Local-only secrets for the AI question pipeline (generate / extract).
#
# 1. Copy this file to ".env"  (cp .env.example .env)
# 2. Paste a key for ONE provider below — whichever token you have.
# 3. NEVER commit .env — it is gitignored, and is only read locally via
#    Node's --env-file flag. It never enters the repo, CI, or the hosted site.
#
# Choose a provider per run with --provider anthropic|google (or it auto-picks
# whichever key is set). Optionally set LLM_PROVIDER to make one the default.

# Anthropic Claude — https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini — two ways to authenticate (pick ONE):
# Needs the SDK once:  npm i -D @google/genai
#
# (a) AI Studio key (simplest, has a free tier) — https://aistudio.google.com/apikey
GEMINI_API_KEY=
#
# (b) Vertex AI via a service account (uses your GCP project's billing/credit).
#     Enable the "Vertex AI API", create a service account with role
#     "Vertex AI User", download its JSON key, then set:
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account-key.json   # keep OUTSIDE the repo

# LLM_PROVIDER=google
