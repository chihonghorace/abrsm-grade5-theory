{
  "name": "abrsm-grade5-theory",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "A free, static study & mock-exam app for ABRSM Grade 5 Music Theory.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "questions:validate": "node scripts/validate.mjs",
    "questions:generate": "node --env-file=.env scripts/generate.mjs",
    "questions:import": "node scripts/import.mjs",
    "questions:extract": "node --env-file=.env scripts/extract-paper.mjs"
  },
  "dependencies": {
    "abcjs": "^6.4.3",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.103.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
